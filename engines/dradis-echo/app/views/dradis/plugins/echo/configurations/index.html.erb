<% content_for :title, 'Dradis Echo Configuration' %>

<% content_for :breadcrumbs do %>
  <ol class="breadcrumb">
    <% if defined?(Dradis::Pro) %>
      <li class="breadcrumb-item"><%= link_to 'Dashboard', main_app.dashboard_path %></li>
      <li class="breadcrumb-item"><%= link_to 'Dradis Echo', echo.prompts_path %></li>
    <% else %>
      <li class="breadcrumb-item"><%= link_to Project.new.name, main_app.project_path(1) %></li>
    <% end %>
    <li class="breadcrumb-item active">Echo Configuration</li>
  </ol>
<% end %>

<p class="text-body-secondary mb-4">AI settings apply to everyone using AI tools and features in your account.</p>

<%= render 'dradis/plugins/echo/configurations/provider', providers: @providers %>

<%= form_with model: @configuration_form, url: configurations_path, method: :patch do |f| %>
  <% @configuration_form.class.agents.each do |agent| %>
    <%= f.fields_for agent.form_key do |cf| %>
      <%= render "dradis/plugins/echo/configurations/#{agent.name.demodulize.underscore}", f: cf, providers: @providers %>
    <% end %>
  <% end %>

  <div class="form-actions">
    <%= f.submit 'Save configuration', class: 'btn btn-primary' %>
  </div>
<% end %>
