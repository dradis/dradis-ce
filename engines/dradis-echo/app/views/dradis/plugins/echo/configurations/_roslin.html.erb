<div class="card mb-4" data-controller="dradis--plugins--echo--agent">
  <div class="card-body">
    <div class="d-flex align-items-start gap-3 mb-1">
      <div class="form-check form-switch mt-1 flex-shrink-0">
        <%= f.check_box :enabled,
              class: 'form-check-input',
              role: 'switch',
              data: { agent_switch: '', action: 'change->dradis--plugins--echo--agent#toggle' } %>
      </div>
      <div>
        <h5 class="card-title mb-1">Roslin</h5>
        <p class="text-body-secondary mb-2">AI-assisted text analysis for project records. Enable to allow users to run prompts against issues.</p>
      </div>
    </div>

    <div class="card mb-0" data-dradis--plugins--echo--agent-target="tool">
      <div class="card-body">
        <div class="d-flex align-items-start gap-3 mb-3">
          <div class="form-check form-switch mt-1 flex-shrink-0">
            <%= f.check_box :issue_interaction_enabled,
                  class: 'form-check-input',
                  role: 'switch',
                  disabled: @providers.none?,
                  data: { tool_switch: '', action: 'change->dradis--plugins--echo--agent#toggle' } %>
          </div>
          <div>
            <h6 class="mb-1">Issue Interaction</h6>
            <p class="text-body-secondary small mb-0">Run prompts against issues and stream responses in real time.</p>
          </div>
        </div>

        <div data-tool-fields>
          <% if @providers.any? %>
            <div class="row g-3">
              <div class="col-lg-6">
                <%= f.label :issue_interaction_provider_id, 'Provider', class: 'form-label' %>
                <%= render 'dradis/plugins/echo/configurations/issue_interaction_provider_select', f: f %>
              </div>
              <div class="col-lg-6">
                <%= f.label :issue_interaction_model, 'Model override', class: 'form-label' %>
                <%= f.text_field :issue_interaction_model, class: 'form-control', placeholder: "Uses provider's default model" %>
                <div class="form-text">Leave blank to use the provider's default model.</div>
              </div>
            </div>
          <% else %>
            <div class="alert alert-warning mb-0">
              No providers configured. <%= link_to 'Add a provider', new_provider_path %> before enabling Issue Interaction.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
