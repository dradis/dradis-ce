<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex align-items-start justify-content-between mb-1">
      <div>
        <h5 class="card-title mb-1">Roslin</h5>
        <p class="text-body-secondary mb-0">AI-assisted text analysis for project records. Enable to allow users to run prompts against issues and other record types.</p>
      </div>
      <div class="form-check form-switch ms-4 flex-shrink-0">
        <%= f.check_box :enabled, class: 'form-check-input', role: 'switch' %>
      </div>
    </div>

    <hr>

    <%# Issue Interaction %>
    <div class="d-flex align-items-start justify-content-between mb-3">
      <div>
        <h6 class="mb-1">Issue Interaction</h6>
        <p class="text-body-secondary small mb-0">Run prompts against issues and stream responses in real time.</p>
      </div>
      <div class="form-check form-switch ms-4 flex-shrink-0">
        <%= f.check_box :issue_interaction_enabled, class: 'form-check-input', role: 'switch' %>
      </div>
    </div>
    <div class="row g-3 mb-4 ps-3 border-start">
      <div class="col-md-6">
        <%= f.label :issue_interaction_provider_id, 'Provider', class: 'form-label' %>
        <%= f.select :issue_interaction_provider_id,
            providers.map { |p| [p.name, p.id] },
            { include_blank: 'Select a provider' },
            class: 'form-select' %>
        <div class="form-text">Which provider to use for this feature.</div>
      </div>
      <div class="col-md-6">
        <%= f.label :issue_interaction_model, 'Model override', class: 'form-label' %>
        <%= f.text_field :issue_interaction_model, class: 'form-control', placeholder: "Uses provider's default model" %>
        <div class="form-text">Leave blank to use the provider's default model.</div>
      </div>
    </div>

    <hr>

    <%# LanguageTool %>
    <div class="d-flex align-items-start justify-content-between mb-3">
      <div>
        <h6 class="mb-1">LanguageTool</h6>
        <p class="text-body-secondary small mb-0">Open-source grammar and style checker. Requires a running LanguageTool instance.</p>
      </div>
      <div class="form-check form-switch ms-4 flex-shrink-0">
        <%= f.check_box :language_tool_enabled, class: 'form-check-input', role: 'switch' %>
      </div>
    </div>
    <div class="row g-3 mb-3 ps-3 border-start">
      <div class="col-md-6">
        <%= f.label :language_tool_address, 'Address', class: 'form-label' %>
        <%= f.text_field :language_tool_address, class: 'form-control' %>
      </div>
    </div>
  </div>
</div>
