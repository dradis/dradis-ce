<% if Dradis::Plugins::Echo::Roslin::LanguageTool.enabled? %>
  <div data-behavior="grammar-container"
       data-grammar-check-url="<%= echo.project_grammar_check_path(current_project) %>"
       data-grammar-replacements-url="<%= echo.project_grammar_replacements_path(current_project) %>"
       data-commentable-type="<%= @issue.class %>"
       data-commentable-id="<%= @issue.id %>"
       hidden>
  </div>

  <div class="offcanvas offcanvas-end"
       data-behavior="grammar-panel"
       data-bs-backdrop="false"
       data-bs-scroll="true"
       tabindex="-1"
       id="grammar-panel-<%= @issue.id %>">
    <div class="offcanvas-header">
      <h6 class="offcanvas-title">
        <i class="fa-solid fa-spell-check me-1"></i> Grammar Suggestion
      </h6>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body pt-0" data-behavior="grammar-panel-body"></div>
  </div>
<% end %>

<div class="tab-pane" id="echo-tab">
  <div class="inner">
    <h4 class="header-underline">Dradis Echo</h4>

    <turbo-frame id="<%= dom_id(@issue, :echo) %>">
      <div data-behavior="fetch" data-path="<%= echo.project_interactions_path(current_project, type: :issue, record: @issue.id) %>"></div>
    </turbo-frame>
  </div>
</div>
