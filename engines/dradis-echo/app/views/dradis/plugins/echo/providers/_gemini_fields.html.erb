<div class="mb-3">
  <%= f.label :api_key, 'API Key', class: 'form-label' %>
  <%= f.password_field :api_key, class: 'form-control',
      placeholder: provider.api_key.present? ? '(already set)' : nil,
      required: provider.new_record? %>
</div>
<div class="mb-3">
  <%= f.label :model, class: 'form-label' %>
  <%= f.text_field :model, class: 'form-control', placeholder: 'e.g. gemini-2.0-flash', required: true %>
</div>
