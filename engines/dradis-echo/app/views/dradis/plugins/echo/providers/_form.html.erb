<%= form_with model: provider, scope: :provider,
      url: provider.new_record? ? providers_path : provider_path(provider) do |f| %>

  <% if provider.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% provider.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if provider.new_record? %>
    <%= f.hidden_field :type, value: provider.type_name %>

    <div class="mb-3">
      <span class="badge bg-secondary"><%= provider.type_name %></span>
    </div>

    <div class="mb-3">
      <%= f.label :name, class: 'form-label' %>
      <%= f.text_field :name, class: 'form-control', required: true %>
    </div>

    <%= render "dradis/plugins/echo/providers/#{provider.partial_name}_fields", f: f, provider: provider %>

    <div class="form-actions">
      <%= f.submit 'Add Provider', class: 'btn btn-primary' %>
      or <%= link_to 'Cancel', providers_path %>
    </div>

  <% else %>
    <%= f.hidden_field :type %>

    <div class="mb-3">
      <span class="badge bg-secondary"><%= provider.type_name %></span>
    </div>

    <div class="mb-3">
      <%= f.label :name, class: 'form-label' %>
      <%= f.text_field :name, class: 'form-control', required: true %>
    </div>

    <%= render "dradis/plugins/echo/providers/#{provider.partial_name}_fields", f: f, provider: provider %>

    <div class="form-actions">
      <%= f.submit 'Update Provider', class: 'btn btn-primary' %>
      or <%= link_to 'Cancel', providers_path %>
    </div>
  <% end %>

<% end %>
