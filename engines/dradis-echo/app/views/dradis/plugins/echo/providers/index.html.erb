<% content_for :title, 'Echo Providers' %>

<% content_for :breadcrumbs do %>
  <ol class="breadcrumb">
    <% if defined?(Dradis::Pro) %>
      <li class="breadcrumb-item"><%= link_to 'Dashboard', main_app.dashboard_path %></li>
      <li class="breadcrumb-item"><%= link_to 'Dradis Echo', echo.prompts_path %></li>
    <% else %>
      <li class="breadcrumb-item"><%= link_to Project.new.name, main_app.project_path(1) %></li>
    <% end %>
    <li class="breadcrumb-item active">Providers</li>
  </ol>
<% end %>

<div class="content-container">
  <h4 class="header-underline">Providers
    <% if @providers.any? %>
      <span class="actions pt-1">
        <%= link_to new_provider_path do %>
          <i class="fa-solid fa-plus me-1"></i>New Provider
        <% end %>
      </span>
    <% end %>
  </h4>

  <% if @providers.any? %>
    <div class="provider-list">
      <%= render partial: 'provider', collection: @providers %>
    </div>
  <% else %>
    <%= render 'shared/empty_state',
          actions_partial: 'dradis/plugins/echo/providers/empty_state_actions',
          docs_link: 'https://dradis.com/support/guides/echo/providers.html',
          name: 'provider',
          text: 'Use providers to connect Echo to your LLM services. Configure connections to OpenAI, Anthropic, or a self-hosted Ollama instance to power your AI tools.' %>
  <% end %>
</div>
