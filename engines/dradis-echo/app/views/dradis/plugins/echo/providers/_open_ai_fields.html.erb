<div class="mb-3">
  <%= f.label :api_key, 'API Key', class: 'form-label' %>
  <%= f.password_field :api_key, class: 'form-control',
      placeholder: provider.api_key.present? ? '(already set)' : nil,
      required: provider.new_record? %>
</div>
<div class="mb-3">
  <%= f.label :model, class: 'form-label' %>
  <%= f.text_field :model, class: 'form-control', placeholder: 'e.g. gpt-4o', required: true %>
</div>
<div class="mb-3">
  <%= f.label :address, 'API Base URL', class: 'form-label' %>
  <%= f.text_field :address, class: 'form-control', placeholder: 'https://api.openai.com/v1/' %>
  <div class="form-text">Leave blank to use the default OpenAI endpoint (<code>https://api.openai.com/v1/</code>). Set this to connect to a self-hosted OpenAI-compatible service instead.</div>
</div>
