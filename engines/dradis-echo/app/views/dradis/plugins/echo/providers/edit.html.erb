<% content_for :title, 'Edit Provider' %>

<% content_for :breadcrumbs do %>
  <ol class="breadcrumb">
    <% if defined?(Dradis::Pro) %>
      <li class="breadcrumb-item"><%= link_to 'Dashboard', main_app.dashboard_path %></li>
      <li class="breadcrumb-item"><%= link_to 'Dradis Echo', echo.prompts_path %></li>
    <% else %>
      <li class="breadcrumb-item"><%= link_to Project.new.name, main_app.project_path(1) %></li>
    <% end %>
    <li class="breadcrumb-item"><%= link_to 'Providers', providers_path %></li>
    <li class="breadcrumb-item active">Edit Provider</li>
  </ol>
<% end %>

<div class="content-container">
  <h4 class="header-underline">Edit Provider</h4>
  <%= render 'form', provider: @provider %>
</div>
