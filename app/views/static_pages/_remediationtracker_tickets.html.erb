<% tickets = [
  {
    title:    'SQL Injection in Login Form',
    category: 'Security',
    state:    'Open',
    assignee: 'James T. Kirk',
    due_at:   Date.today - 1.week,
    overdue:  true
  },
  {
    title:    'Outdated SSL Certificate',
    category: 'Infrastructure',
    state:    'In Progress',
    assignee: 'Nyota Uhura',
    due_at:   Date.today,
    overdue:  true
  },
  {
    title:    'Cross-Site Scripting in Search Bar',
    category: 'Security',
    state:    'Open',
    assignee: 'Montgomery Scott',
    due_at:   Date.today + 1.week,
    overdue:  false
  },
  {
    title:    'Missing HTTP Security Headers',
    category: 'Compliance',
    state:    'In Progress',
    assignee: nil,
    due_at:   Date.today + 1.month,
    overdue:  false
  }
] %>

<div class="dataTables_wrapper">
  <table class="table table-striped dataTable mb-0">
    <thead>
      <tr>
        <th>Title</th>
        <th>Category</th>
        <th>State</th>
        <th>Assignee</th>
        <th>Due date</th>
        <th class="no-sort"><span class="visually-hidden">Actions</span></th>
      </tr>
    </thead>
    <tbody>
      <% tickets.each_with_index do |ticket, index| %>
        <tr id="ticket-<%= index %>">
          <td>
            <a
              href="javascript:void(0)"
              class="js-try-pro"
              data-term="remediation"
              data-url="https://dradis.com/pro/pages/remediation.html">
              <%= ticket[:title] %>
            </a>
          </td>
          <td><%= ticket[:category] %></td>
          <td><%= ticket[:state] %></td>
          <td>
            <% if ticket[:assignee] %>
              <%= ticket[:assignee] %>
            <% else %>
              <span class="text-muted">(no one yet)</span>
            <% end %>
          </td>
          <td>
            <time class="<%= 'text-danger' if ticket[:overdue] %>">
              <%= ticket[:due_at].strftime('%B %d, %Y') %>
            </time>
          </td>
          <td class="column-actions text-nowrap">
            <a
              href="javascript:void(0)"
              class="btn btn-xs btn-warning js-try-pro"
              data-term="remediation"
              data-url="https://dradis.com/pro/pages/remediation.html">
              <i class="fa-solid fa-pencil"></i> edit
            </a>
            <a
              href="javascript:void(0)"
              class="btn btn-xs btn-danger js-try-pro"
              data-term="remediation"
              data-url="https://dradis.com/pro/pages/remediation.html">
              <i class="fa-solid fa-close"></i> delete
            </a>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
