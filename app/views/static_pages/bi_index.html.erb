<% content_for :title, 'Business Intelligence' %>

<% content_for :breadcrumbs do %>
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><%= link_to 'Dashboard', main_app.root_path %></li>
    <li class="breadcrumb-item active">Business Intelligence</li>
  </ol>
<% end %>

<% content_for :sidebar do %>
  <div class="header">
    <div class="header-inner">
      <h5 class="header-name">BI Dashboard Tips</h5>
      <div class="options">
        <%= link_to '#bi-page-tips', data: { bs_toggle: 'collapse', behavior: 'collapse-collection' } do %>
          <i class="fa-solid fa-chevron-up" data-behavior="toggle-chevron"></i><span class="visually-hidden">Toggle update state</span>
        <% end %>
      </div>
    </div>
  </div>
  <div id="bi-page-tips" class="page-tips show collapse">
    <div class="bg-info">
      <p>The BI Dashboard surfaces stats and analytics across your engagements so you can identify trends and draw conclusions from your security data.</p>
      <p>Get an overview of your <strong>Projects</strong> and <strong>Issues</strong> from the current year, and surface your most common findings to prioritize your security investments.</p>
      <p class="text-end card-link">More about <a href="https://dradis.com/tools/bi.html" target="_blank">Business Intelligence</a>.</p>
    </div>
  </div>
<% end %>

<h1>Your security posture at a glance</h1>
<h2 class="mb-3">Year-over-year insights into your risk reduction</h2>

<div class="row mt-4">
  <div class="col-sm-6 col-xl-3">
    <div class="content-container">
      <div class="d-flex flex-column flex-grow-1 justify-content-center">
        <div class="position-relative d-flex flex-column flex-grow-1">
          <div class="bg-icon">
            <i class="fa-solid fa-briefcase fa-2x"></i>
          </div>
          <h3 class="mb-0 fs-5 title">Projects</h3>
          <h4 class="mb-0"><%= @bi_projects[:current_year_count] %></h4>
          <p class="mb-3">created this year</p>
          <h5 class="<%= class_names('delta', positive: @bi_projects[:yoy_delta] > 0, negative: @bi_projects[:yoy_delta] < 0) %>">
            <i class="fa-solid <%= delta_icon(@bi_projects[:yoy_delta]) %> delta-icon"></i><%= @bi_projects[:yoy_delta].abs %>%
          </h5>
          <p>from <%= @bi_projects[:last_year_count] %> during Jan 1 - <%= Date.today.prev_year.strftime('%b %d %Y') %></p>
        </div>
      </div>
    </div>

    <div class="content-container pro-teaser js-try-pro" data-term="bi" data-url="https://dradis.com/pro/pages/bi.html">
      <div class="d-flex flex-column flex-grow-1 justify-content-center">
        <div class="position-relative d-flex flex-column flex-grow-1">
          <div class="bg-icon">
            <i class="fa-solid fa-people-group fa-2x"></i>
          </div>
          <h3 class="mb-0 fs-5 title">Teams</h3>
          <h4 class="mb-0"><%= @bi_teams[:current_year_count] %></h4>
          <p class="mb-3">active this year</p>
          <h5 class="<%= class_names('delta', positive: @bi_teams[:yoy_delta] > 0, negative: @bi_teams[:yoy_delta] < 0) %>">
            <i class="fa-solid <%= delta_icon(@bi_teams[:yoy_delta]) %> delta-icon"></i><%= @bi_teams[:yoy_delta].abs %>%
          </h5>
          <p>from <%= @bi_teams[:last_year_count] %> during Jan 1 - <%= Date.today.prev_year.strftime('%b %d %Y') %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-3">
    <div class="content-container">
      <div class="d-flex flex-column flex-grow-1 justify-content-center"
           data-behavior="fetch"
           data-path="<%= static_bi_insights_issues_path %>">
        <%= spinner_tag %>
      </div>
    </div>

    <div class="content-container pro-teaser js-try-pro" data-term="bi" data-url="https://dradis.com/pro/pages/bi.html">
      <div class="d-flex flex-column flex-grow-1 justify-content-center">
        <div class="position-relative d-flex flex-column flex-grow-1">
          <div class="bg-icon">
            <i class="fa-solid fa-chalkboard-user fa-2x"></i>
          </div>
          <h3 class="mb-0 fs-5 title">Contributors</h3>
          <h4 class="mb-0"><%= @bi_contributors[:current_year_count] %></h4>
          <p class="mb-3">active this year</p>
          <h5 class="<%= class_names('delta', positive: @bi_contributors[:yoy_delta] > 0, negative: @bi_contributors[:yoy_delta] < 0) %>">
            <i class="fa-solid <%= delta_icon(@bi_contributors[:yoy_delta]) %> delta-icon"></i><%= @bi_contributors[:yoy_delta].abs %>%
          </h5>
          <p>from <%= @bi_contributors[:last_year_count] %> during Jan 1 - <%= Date.today.prev_year.strftime('%b %d %Y') %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-12 col-xl-6">
    <div class="content-container chart top-issues">
      <div class="d-flex flex-column flex-grow-1 justify-content-center"
           data-behavior="fetch"
           data-path="<%= static_bi_insights_top_issues_path %>">
        <%= spinner_tag %>
      </div>
    </div>
  </div>
</div>

<hr class="mt-0">
<div class="row mt-4">
  <div class="col-lg-6">
    <%= render 'static_pages/bi_top_team_properties' %>
    <hr class="d-lg-none">
  </div>
  <div class="col-lg-6">
    <%= render 'static_pages/bi_top_project_properties' %>
  </div>
</div>
