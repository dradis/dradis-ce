<div class="inline-thread" id="inline_thread_<%= thread.id %>" data-behavior="inline-thread" data-thread-id="<%= thread.id %>">
  <div class="d-flex align-items-center gap-2 mb-3">
    <% if thread.resolved? %>
      <span class="badge bg-success">Resolved</span>
    <% else %>
      <span class="badge bg-warning text-dark">Open</span>
    <% end %>
    <% if thread.outdated? %>
      <span class="badge bg-secondary">Outdated</span>
    <% end %>

    <div class="ms-auto d-flex gap-2">
      <% if thread.open? %>
        <%= button_to project_qa_issue_inline_thread_resolution_path(current_project, issue, thread),
              method: :post,
              class: 'btn btn-sm btn-outline-primary' do %>
          <i class="fa-solid fa-check me-1"></i>Resolve
        <% end %>
      <% else %>
        <%= button_to project_qa_issue_inline_thread_resolution_path(current_project, issue, thread),
              method: :delete,
              class: 'btn btn-sm btn-outline-secondary' do %>
          <i class="fa-solid fa-rotate-left me-1"></i>Reopen
        <% end %>
      <% end %>

      <% if thread.user_id == current_user.id %>
        <%= button_to project_qa_issue_inline_thread_path(current_project, issue, thread),
              method: :delete,
              class: 'btn btn-sm btn-outline-danger',
              data: { turbo_confirm: 'Delete this thread and all its comments?' } do %>
          <i class="fa-solid fa-xmark me-1"></i>Delete
        <% end %>
      <% end %>
    </div>
  </div>
  <blockquote class="thread-quoted-text border-start border-3 border-primary ps-3 text-muted fst-italic mt-4">
    <%= thread.quoted_text %>
  </blockquote>

  <div class="border-top" id="thread_<%= thread.id %>_comments">
    <% thread.comments.includes(:user).each do |comment| %>
      <%= render 'qa/inline_threads/inline_comment', comment: comment %>
    <% end %>
  </div>

  <hr class="mt-0">

  <div id="thread_<%= thread.id %>_reply_form">
    <%= form_with url: project_qa_issue_inline_thread_comments_path(current_project, issue, thread) do |f| %>
      <%= f.text_area :content,
            name: 'comment[content]',
            class: 'form-control form-control-sm mb-2',
            placeholder: 'Reply...',
            rows: 2 %>
      <%= f.submit 'Reply', class: 'btn btn-sm btn-primary' %>
    <% end %>
  </div>
</div>
