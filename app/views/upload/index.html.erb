<% content_for :title, 'Upload' %>

<% content_for :breadcrumbs do %>
  <ol class="breadcrumb">
    <li class="breadcrumb-item">
      <%= link_to current_project.name, project_path(current_project) %>
    </li>
    <li class="breadcrumb-item active">
      Upload
    </li>
  </ol>
<% end %>

<div class="row p-0">
  <div class="col-lg-6 col-xl-5 mb-4">
    <div class="content-container mb-0 h-100">
      <h4 class="header-underline">Upload Output Files</h4>

      <div class="mt-4"
           data-controller="upload-manager"
           data-upload-manager-upload-url-value="<%= project_upload_manager_path(current_project) %>"
           data-upload-manager-parse-url-value="<%= project_upload_parse_path(current_project) %>"
           data-action="upload-file:changed->upload-manager#rowChanged upload-file:removed->upload-manager#rowRemoved">

        <div class="upload-drop-zone mb-4"
             data-upload-manager-target="dropZone"
             data-action="click->upload-manager#openFilePicker drop->upload-manager#drop dragover->upload-manager#dragOver dragleave->upload-manager#dragLeave">
          <p class="mb-1"><strong>Drop files here</strong> or click to browse</p>
          <p class="text-muted small mb-0">Tool is auto-detected per file. You can override per row.</p>
        </div>

        <input type="file" multiple name="upload_files" class="d-none"
               data-upload-manager-target="fileInput"
               data-action="change->upload-manager#filesSelected">

        <div class="mb-4">
          <%= label_tag :state do %>
            <h5>State of uploaded records</h5>
          <% end %>
          <%= select_tag 'state',
                options_for_select(Issue.states.map { |s, _id| [s.humanize, s] }),
                class: 'form-select',
                data: { 'upload-manager-target': 'stateSelect' } %>
        </div>

        <div data-upload-manager-target="stagingArea" class="upload-staging-area mb-3"></div>

        <template data-upload-manager-target="rowTemplate">
          <%= render 'row', uploaders: @uploaders %>
        </template>

        <button class="btn btn-primary" disabled
                data-upload-manager-target="uploadButton"
                data-action="click->upload-manager#upload">
          Upload
        </button>
      </div>
    </div>
  </div>

  <div class="col-lg-6 col-xl-7 mb-4">
    <div class="content-container mb-0 h-100">
      <h4 class="header-underline">Available plugins</h4>
      <ul class="mt-3 ps-3">
        <% @uploaders.each do |uploader| %>
          <li><%= uploader.name %></li>
        <% end %>
      </ul>
    </div>
  </div>
</div>

<% Dradis::Plugins.with_feature(:upload).flat_map { |e| e.try(:upload_detectors) || [] }.each do |detector_id| %>
  <script type="module">import "<%= detector_id %>"</script>
<% end %>
