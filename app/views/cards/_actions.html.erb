<div class="actions">
  <% if @lists.count > 1 %>
    <span class="action dropdown">
      <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown"><i class="fa-solid fa-table-columns fa-fw"></i> <%= @list.name %></a>
      <div class="dropdown-menu">
        <% @lists.each do |list| %>
          <% if list.id == @list.id %>
            <a href="javascript:void(0)" class="dropdown-item disabled"><%= list.name %></a>
          <% else %>
            <%= link_to(
              move_to_list_project_board_list_card_path(current_project, @board, @list, @card, new_list_id: list.id),
              method: :post,
              class: 'dropdown-item'
            ) do %>
              <%= list.name %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </span>
  <% end %>
  <span class="action">
    <%= link_to edit_project_board_list_card_path(current_project, @board, @list, @card) do %>
      <i class="fa-solid fa-pencil fa-fw"></i> Edit
    <% end %>
  </span>
  <div class="dropdown dots-dropdown">
    <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown"><i class="fa-solid fa-ellipsis-h fa-lg"></i><span class="visually-hidden">Toggle menu</span></a>
    <div class="dropdown-menu">
      <%= link_to(
          project_board_list_card_path(current_project, @board, @list, @card),
          class: 'dropdown-item text-error-hover',
          data: { confirm: "Are you sure?\n\nProceeding will delete this card from the task list." },
          method: :delete
        ) do %>
        <i class="fa-solid fa-trash fa-fw"></i> Delete
      <% end %>
      <%= render partial: 'subscriptions/actions', locals: { subscribable: @card, dots_menu: true } %>
      <%= link_to(project_board_list_card_revisions_path(current_project, @board, @list, @card), class: 'dropdown-item') do %>
        <i class="fa-solid fa-history fa-fw"></i> View History
      <% end %>
    </div>
  </div>
</div>
